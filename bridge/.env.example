# =============================================
#   CREDORA BRIDGE — Environment Variables
# =============================================

# Server Port
PORT=3001

# Polygon Amoy Testnet RPC URL
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Deployed CredoraCertificate Contract Address
CONTRACT_ADDRESS=0xfE2e5b70EB94f2A7E54Cc6508885d48dCd2042c4

# Private key of the ISSUER wallet (same key used during contract deployment OR a new authorized wallet)
# ⚠️  NEVER commit the real .env file to GitHub!
ISSUER_PRIVATE_KEY=your_private_key_here

# Laravel Backend URL (for internal communication)
LARAVEL_URL=http://localhost:8000
